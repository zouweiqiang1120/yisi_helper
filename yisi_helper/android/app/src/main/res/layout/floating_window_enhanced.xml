<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_container"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_bg_enhanced"
    android:padding="12dp"
    android:elevation="8dp">

    <!-- 标题栏（可拖动） -->
    <LinearLayout
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/drag_handle_bg"
        android:padding="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📚 易思助手"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_toggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/arrow_down_float"
            android:tint="#FFFFFF"
            android:contentDescription="展开/收起" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF"
            android:contentDescription="关闭" />
    </LinearLayout>

    <!-- 内容区域 -->
    <LinearLayout
        android:id="@+id/layout_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <!-- 题目预览 -->
        <TextView
            android:id="@+id/tv_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="正在识别题目..."
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- 选项显示 -->
        <TextView
            android:id="@+id/tv_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="#B0B0B0"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.2" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#33FFFFFF" />

        <!-- 答案显示 -->
        <TextView
            android:id="@+id/tv_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="答案: --"
            android:textColor="#4CAF50"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- 答案详情（选项内容） -->
        <TextView
            android:id="@+id/tv_answer_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="#81C784"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- 控制面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:background="#22FFFFFF"
            android:visibility="visible">

            <!-- 透明度控制 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="透明"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />

                <SeekBar
                    android:id="@+id/seekbar_alpha"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="90" />

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="不透明"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- 缩放控制 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="缩小"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />

                <SeekBar
                    android:id="@+id/seekbar_scale"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="50" />

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="放大"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- 提示信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="💡 拖动标题栏移动 | 调节滑块改变透明度和大小"
            android:textColor="#888888"
            android:textSize="9sp"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>
